{{!--
  ============================================================================
  File  : my_middleware_config_template.h.hbs
  Brief : Handlebars template for the generated configuration header.

  STM32CubeMX2 renders this template against the user's configuration
  (stored in the project lock-file) and writes the output to:
      <project>/my_middleware_config.h

  Available data:
    @root.SWConfigurationAPI  — access to component configuration instances
    @root.mw_params           — shortcut assigned below to the "buffer" section

  Template engine: Handlebars (STM32CubeMX2 extended flavour)
  ============================================================================
--}}
{{!-- Retrieve user configuration for this component --}}
{{assign 'mw_filter'    (JSONparse '{"cgroup": "STM32CubeMX2 Config", "csub": "MyMiddleware"}')~}}
{{assign 'mw_context'   (@root.SWConfigurationAPI.getInstancesConfiguration @root.mw_filter)~}}
{{assign 'mw_buffer'    @root.mw_context.[0].settings.parameters.core.buffer~}}
{{assign 'mw_components' @root.mw_context.[0].settings.parameters.components.pack_components~}}
{{log "MyMiddleware buffer params:" (toJSON @root.mw_buffer)~}}
{{log "MyMiddleware component params:" (toJSON @root.mw_components)~}}
/**
  ******************************************************************************
  * @file    my_middleware_config.h
  * @brief   Auto-generated configuration for My Middleware.
  *          DO NOT EDIT — regenerate via STM32CubeMX2.
  *
{{> LICENSE}}

/* Define to prevent recursive inclusion ------------------------------------ */
#ifndef MY_MIDDLEWARE_CONFIG_H
#define MY_MIDDLEWARE_CONFIG_H

#ifdef __cplusplus
extern "C" {
#endif /* __cplusplus */

/* ============================================================
   Buffer configuration
   Generated from: Parameters > Core > Buffer configuration
   ============================================================ */

/**
 * @brief Size of the internal ring buffer in bytes.
 *
 * Configured value : {{@root.mw_buffer.buffer_size}} bytes
 * Valid range      : 16 – 65536
 * Recommendation  : use a power of two for optimal modulo performance.
 */
#define MY_MIDDLEWARE_BUFFER_SIZE  {{@root.mw_buffer.buffer_size}}U

/**
 * @brief Overwrite-on-overflow behaviour.
 *
 * When set to 1, MyMW_Write() silently overwrites the oldest unread byte
 * when the buffer is full.  When set to 0, MyMW_Write() returns MY_MW_BUSY.
 */
{{#if @root.mw_buffer.enable_overwrite}}
#define MY_MIDDLEWARE_OVERWRITE_ENABLED  1U
{{else}}
#define MY_MIDDLEWARE_OVERWRITE_ENABLED  0U
{{/if}}

/*
 * OpenCMSIS-Pack component model used by this template:
 * - Core         : always required
 * - Component A  : always required by the CubeMX2 config component
 * - Component B  : optional, driven by the CubeMX2 boolean below
 */
#define MY_MIDDLEWARE_COMPONENT_A_ENABLED  1U
{{#if @root.mw_components.enable_component_b}}
#define MY_MIDDLEWARE_COMPONENT_B_ENABLED  1U
{{else}}
#define MY_MIDDLEWARE_COMPONENT_B_ENABLED  0U
{{/if}}

#ifdef __cplusplus
}
#endif /* __cplusplus */

#endif /* MY_MIDDLEWARE_CONFIG_H */
